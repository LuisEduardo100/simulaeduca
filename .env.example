# SimulaEduca — Copie para .env.local e preencha com seus valores

PORT=3000

# Banco de Dados (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/simulaeduca_db"
DIRECT_URL="postgresql://user:password@localhost:5432/simulaeduca_db"

# Autenticacao (NextAuth v5) — gere com: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# Pinecone — https://app.pinecone.io/
PINECONE_API_KEY=""
PINECONE_INDEX="simulaeduca"
PINECONE_ENVIRONMENT="gcp-starter"

# AWS S3
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="simulaeduca-pdfs"
AWS_REGION="sa-east-1"

# Stripe — https://dashboard.stripe.com/
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Email (Resend) — https://resend.com/api-keys
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@simulaeduca.com.br"

# Sentry — https://sentry.io/
SENTRY_DSN=""

# PostHog — https://posthog.com/
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# Redis
REDIS_URL="redis://localhost:6379"
