# =============================================================
# SimulaEduca — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha com seus valores
# =============================================================

# ── Banco de Dados ────────────────────────────────────────────────────────────
# URL de conexão do PostgreSQL
# Local (Docker):     postgresql://simulaeduca:simulaeduca_dev_password@localhost:5432/simulaeduca_db
# Neon (produção):    postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/simulaeduca?sslmode=require
# Supabase (prod):    postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
DATABASE_URL="postgresql://simulaeduca:pswrd@localhost:5432/simulaeduca_db"

# URL direta para migrations do Prisma (bypassa connection pooler)
# Em desenvolvimento local pode ser igual a DATABASE_URL
DIRECT_URL="postgresql://simulaeduca:pswrd@localhost:5432/simulaeduca_db"

# ── Autenticação (NextAuth.js v5) ─────────────────────────────────────────────
# Gere um secret seguro com: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"

# URL da aplicação (sem trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth — Crie em https://console.cloud.google.com/
# APIs & Services > Credentials > Create OAuth 2.0 Client ID
# URI autorizado: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── Inteligência Artificial ───────────────────────────────────────────────────
# OpenAI — https://platform.openai.com/api-keys
# Modelo principal: gpt-4o | Embeddings: text-embedding-3-small
OPENAI_API_KEY="sk-proj-..."

# Anthropic Claude — https://console.anthropic.com/
# Modelo alternativo: claude-3-5-sonnet-20241022
ANTHROPIC_API_KEY="sk-ant-..."

# ── Banco Vetorial ────────────────────────────────────────────────────────────
# OPÇÃO 1: Pinecone — https://app.pinecone.io/
# Crie um índice com dimension=1536 e metric=cosine
PINECONE_API_KEY="..."
PINECONE_INDEX="simulaeduca"
PINECONE_ENVIRONMENT="gcp-starter"

# OPÇÃO 2: pgvector — Usar o próprio PostgreSQL (DATABASE_URL acima)
# Nenhuma variável adicional necessária. Extensão habilitada via docker/init.sql

# ── Armazenamento de PDFs ─────────────────────────────────────────────────────
# AWS S3 — https://aws.amazon.com/s3/
# Alternativa: Cloudflare R2 (compatível com API S3)
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
AWS_S3_BUCKET="simulaeduca-pdfs"
AWS_REGION="sa-east-1"

# ── Pagamentos (Stripe) ───────────────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com/
# ATENÇÃO: Use chaves de TEST (sk_test_) em desenvolvimento!
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Webhook secret — obtenha ao configurar o webhook no Stripe Dashboard
# Para dev local, use o Stripe CLI: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── E-mail Transacional (Resend) ──────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@simulaeduca.com.br"

# ── Monitoramento e Analytics ─────────────────────────────────────────────────
# Sentry — https://sentry.io/
SENTRY_DSN="https://...@o0.ingest.sentry.io/..."

# PostHog — https://posthog.com/
# NEXT_PUBLIC_ expõe a variável ao client-side (browser)
NEXT_PUBLIC_POSTHOG_KEY="phc_..."
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ── Redis (Cache / Rate Limiting / Filas) ─────────────────────────────────────
# Local (Docker): redis://localhost:6379
# Produção (Upstash): rediss://default:password@region.upstash.io:6380
REDIS_URL="redis://localhost:6379"
