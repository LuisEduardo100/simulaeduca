generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [uuidOssp(map: "uuid-ossp"), vector]
}

// ─── Auth (NextAuth.js v5 / Auth.js) ─────────────────────────────────────────

model User {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email            String    @unique
  name             String?
  emailVerified    DateTime?
  image            String?
  role             String    @default("teacher") // teacher, admin, coordinator
  school           String?
  city             String?
  state            String?   @db.Char(2)
  passwordHash     String?   @map("password_hash") // senha local (bcrypt), null para usuários OAuth-only
  planType         String    @default("free") @map("plan_type") // free, basic, pro, school, secretaria
  creditsBalance   Int       @default(10) @map("credits_balance")
  stripeCustomerId String?   @map("stripe_customer_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  accounts           Account[]
  sessions           Session[]
  exams              Exam[]
  creditTransactions CreditTransaction[]
  materialChunks     MaterialChunk[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @db.Uuid @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @db.Uuid @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Domínio Educacional ──────────────────────────────────────────────────────

model Subject {
  id   Int    @id @default(autoincrement())
  name String // Matemática, Língua Portuguesa
  slug String @unique // matematica, portugues

  themes      Theme[]
  descriptors Descriptor[]
  exams       Exam[]

  @@map("subjects")
}

model GradeLevel {
  id    Int    @id @default(autoincrement())
  name  String // 5º ano, 9º ano
  slug  String @unique // 5_ano, 9_ano
  level String // fundamental, medio

  themes      Theme[]
  descriptors Descriptor[]
  exams       Exam[]

  @@map("grade_levels")
}

model Evaluation {
  id   Int    @id @default(autoincrement())
  name String // SPAECE, SAEB
  slug String @unique // spaece, saeb

  themes      Theme[]
  descriptors Descriptor[]
  exams       Exam[]

  @@map("evaluations")
}

model Theme {
  id           Int     @id @default(autoincrement())
  evaluationId Int     @map("evaluation_id")
  subjectId    Int     @map("subject_id")
  gradeLevelId Int     @map("grade_level_id")
  name         String // "Interagindo com Números e Funções"
  romanNumeral String? @map("roman_numeral") // "I", "II", "III", "IV"

  evaluation  Evaluation   @relation(fields: [evaluationId], references: [id])
  subject     Subject      @relation(fields: [subjectId], references: [id])
  gradeLevel  GradeLevel   @relation(fields: [gradeLevelId], references: [id])
  descriptors Descriptor[]

  @@map("themes")
}

model Descriptor {
  id           Int    @id @default(autoincrement())
  code         String // D07, D08, D17...
  description  String
  themeId      Int    @map("theme_id")
  evaluationId Int    @map("evaluation_id")
  subjectId    Int    @map("subject_id")
  gradeLevelId Int    @map("grade_level_id")

  theme         Theme          @relation(fields: [themeId], references: [id])
  evaluation    Evaluation     @relation(fields: [evaluationId], references: [id])
  subject       Subject        @relation(fields: [subjectId], references: [id])
  gradeLevel    GradeLevel     @relation(fields: [gradeLevelId], references: [id])
  examQuestions ExamQuestion[]
  questionBank  QuestionBank[]

  @@unique([code, evaluationId, subjectId, gradeLevelId])
  @@map("descriptors")
}

// ─── Simulados ────────────────────────────────────────────────────────────────

model Exam {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String    @db.Uuid @map("user_id")
  title           String
  teacherName     String    @map("teacher_name")
  schoolName      String?   @map("school_name")
  evaluationId    Int       @map("evaluation_id")
  subjectId       Int       @map("subject_id")
  gradeLevelId    Int       @map("grade_level_id")
  status          String    @default("draft") // draft, generating, completed, failed, partial
  totalQuestions  Int       @default(0) @map("total_questions")
  expectedQuestions Int     @default(0) @map("expected_questions")
  creditsConsumed Int       @default(0) @map("credits_consumed")
  headerConfig    Json?     @map("header_config") // { mode: "standard"|"custom"|"none", imageUrl?, teacherName?, school?, discipline?, class?, examDate? }
  difficulty      String?   // facil, medio, dificil, misto — dificuldade geral da prova
  descriptorDistribution Json? @map("descriptor_distribution") // [{descriptorId, questionCount, difficulty?}] para retomada
  pdfUrl          String?   @map("pdf_url")
  answerSheetUrl  String?   @map("answer_sheet_url")
  answerKeyUrl    String?   @map("answer_key_url")
  createdAt       DateTime  @default(now()) @map("created_at")
  completedAt     DateTime? @map("completed_at")

  user               User                @relation(fields: [userId], references: [id])
  evaluation         Evaluation          @relation(fields: [evaluationId], references: [id])
  subject            Subject             @relation(fields: [subjectId], references: [id])
  gradeLevel         GradeLevel          @relation(fields: [gradeLevelId], references: [id])
  questions          ExamQuestion[]
  creditTransactions CreditTransaction[]

  @@map("exams")
}

model ExamQuestion {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  examId           String   @db.Uuid @map("exam_id")
  questionNumber   Int      @map("question_number")
  descriptorId     Int      @map("descriptor_id")
  stem             String // Enunciado
  optionA          String   @map("option_a")
  optionB          String   @map("option_b")
  optionC          String   @map("option_c")
  optionD          String   @map("option_d")
  correctAnswer    String   @db.Char(1) @map("correct_answer") // A, B, C ou D
  justification    String?
  difficulty       String   @default("medio") // facil, medio, dificil
  hasImage         Boolean  @default(false) @map("has_image")
  imageDescription String?  @map("image_description")
  generationModel  String?  @map("generation_model") // gpt-4o, claude-3.5-sonnet
  createdAt        DateTime @default(now()) @map("created_at")

  exam       Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)
  descriptor Descriptor @relation(fields: [descriptorId], references: [id])

  @@map("exam_questions")
}

// ─── Créditos e Planos ────────────────────────────────────────────────────────

model CreditTransaction {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @db.Uuid @map("user_id")
  amount          Int // positivo = adição, negativo = consumo
  type            String // purchase, subscription, usage, bonus
  description     String?
  examId          String?  @db.Uuid @map("exam_id")
  stripePaymentId String?  @map("stripe_payment_id")
  createdAt       DateTime @default(now()) @map("created_at")

  user User  @relation(fields: [userId], references: [id])
  exam Exam? @relation(fields: [examId], references: [id])

  @@map("credit_transactions")
}

model Plan {
  id                  Int      @id @default(autoincrement())
  name                String
  slug                String   @unique // free, basic, pro, school, secretaria
  priceMonthly        Decimal? @map("price_monthly") @db.Decimal(10, 2)
  creditsMonthly      Int?     @map("credits_monthly")
  maxQuestionsPerExam Int?     @map("max_questions_per_exam")
  stripePriceId       String?  @map("stripe_price_id")
  features            Json?
  isActive            Boolean  @default(true) @map("is_active")

  @@map("plans")
}

// ─── Materiais RAG (base de conhecimento vetorizada) ─────────────────────────

model MaterialChunk {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content        String   // texto do chunk
  sourceType     String   @map("source_type") // pdf, docx, txt, text
  sourceFileName String?  @map("source_file_name")
  descriptorCode String?  @map("descriptor_code") // "D07" (metadata para filtro)
  subjectSlug    String?  @map("subject_slug")     // "matematica"
  gradeLevelSlug String?  @map("grade_level_slug") // "9_ano"
  evaluationSlug String?  @map("evaluation_slug")  // "spaece"
  difficulty     String?  // facil, medio, dificil
  chunkIndex     Int      @map("chunk_index")
  totalChunks    Int      @map("total_chunks")
  uploadedBy     String   @db.Uuid @map("uploaded_by")
  // Embedding para busca semântica RAG (text-embedding-3-small = 1536 dims)
  embedding      Unsupported("vector(1536)")?
  createdAt      DateTime @default(now()) @map("created_at")

  uploader User @relation(fields: [uploadedBy], references: [id])

  @@map("material_chunks")
}

// ─── Banco de Questões com pgvector ──────────────────────────────────────────

model QuestionBank {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  descriptorId  Int      @map("descriptor_id")
  stem          String
  optionA       String   @map("option_a")
  optionB       String   @map("option_b")
  optionC       String   @map("option_c")
  optionD       String   @map("option_d")
  correctAnswer String   @db.Char(1) @map("correct_answer")
  justification String?
  difficulty    String?
  qualityScore  Decimal? @map("quality_score") @db.Decimal(3, 2) // 0.00 a 1.00
  timesUsed     Int      @default(0) @map("times_used")
  flagged       Boolean  @default(false)
  // Embedding para busca semântica RAG (text-embedding-3-small = 1536 dims)
  embedding     Unsupported("vector(1536)")?
  createdAt     DateTime @default(now()) @map("created_at")

  descriptor Descriptor @relation(fields: [descriptorId], references: [id])

  @@map("question_bank")
}
