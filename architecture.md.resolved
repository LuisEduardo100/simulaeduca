## Modelo de Dados (12 modelos Prisma)

```mermaid
erDiagram
  User ||--o{ Account : "OAuth accounts"
  User ||--o{ Session : sessions
  User ||--o{ Exam : "cria simulados"
  User ||--o{ CreditTransaction : "transações de crédito"
  User ||--o{ MaterialChunk : "uploads RAG"

  Subject ||--o{ Theme : temas
  Subject ||--o{ Descriptor : descritores
  Subject ||--o{ Exam : simulados
  GradeLevel ||--o{ Theme : temas
  GradeLevel ||--o{ Descriptor : descritores
  GradeLevel ||--o{ Exam : simulados
  Evaluation ||--o{ Theme : temas
  Evaluation ||--o{ Descriptor : descritores
  Evaluation ||--o{ Exam : simulados

  Theme ||--o{ Descriptor : descritores
  Descriptor ||--o{ ExamQuestion : questões
  Descriptor ||--o{ QuestionBank : banco

  Exam ||--o{ ExamQuestion : questões
  Exam ||--o{ CreditTransaction : cobranças

  User {
    uuid id PK
    string email UK
    string name
    string role "teacher/admin/coordinator"
    string planType "free/basic/pro/school/secretaria"
    int creditsBalance "default 10"
    string passwordHash "bcrypt (null = OAuth-only)"
  }

  Exam {
    uuid id PK
    uuid userId FK
    string title
    string status "draft/generating/completed/failed"
    int totalQuestions
    int creditsConsumed
  }

  ExamQuestion {
    uuid id PK
    uuid examId FK
    int questionNumber
    int descriptorId FK
    string stem "enunciado"
    string optionA
    string optionB
    string optionC
    string optionD
    char correctAnswer "A/B/C/D"
    string justification
    string difficulty "facil/medio/dificil"
  }

  Descriptor {
    int id PK
    string code "D07, D08..."
    string description
    int themeId FK
    int evaluationId FK
    int subjectId FK
    int gradeLevelId FK
  }

  QuestionBank {
    uuid id PK
    int descriptorId FK
    string stem
    vector embedding "1536 dims"
    decimal qualityScore
    int timesUsed
  }

  MaterialChunk {
    uuid id PK
    string content
    string sourceType "pdf/docx/txt/text"
    vector embedding "1536 dims"
    string descriptorCode
  }
```

